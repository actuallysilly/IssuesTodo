<Window x:Class="IssuesTodo.Views.ReviewReminderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Project Review" Width="400" SizeToContent="Height" MaxHeight="600"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <StackPanel Margin="24">
        <TextBlock Text="Project Review"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,8"/>
        <TextBlock Text="Review your shelved projects — would you like to continue with any of these?"
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <!-- Archived -->
        <TextBlock x:Name="ArchivedHeader"
                   Text="ARCHIVED"
                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                   Opacity="0.5" Margin="0,0,0,6"/>
        <ItemsControl x:Name="ArchivedList" Margin="0,0,0,16">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="0,3">
                        <Button DockPanel.Dock="Right" Content="Restore"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="{Binding}" Click="Restore_Click"
                                Height="28" Padding="10,0" FontSize="11"/>
                        <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    </DockPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Maybe -->
        <TextBlock x:Name="MaybeHeader"
                   Text="MAYBE-PROJECTS"
                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                   Opacity="0.5" Margin="0,0,0,6"/>
        <ItemsControl x:Name="MaybeList" Margin="0,0,0,24">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="0,3">
                        <Button DockPanel.Dock="Right" Content="Make real"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Tag="{Binding}" Click="Promote_Click"
                                Height="28" Padding="10,0" FontSize="11"/>
                        <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                    </DockPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="DISMISS" HorizontalAlignment="Right"
                Style="{StaticResource MaterialDesignFlatButton}"
                Click="Dismiss_Click"/>
    </StackPanel>
</Window>
