<Window x:Class="IssuesTodo.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings" Width="480" Height="580"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <StackPanel Margin="24">
        <TextBlock Text="Settings"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,20"/>

        <!-- Dev root -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DevRootBox" Grid.Column="0"
                     materialDesign:HintAssist.Hint="Dev root folder (e.g. D:\dev)"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <Button Grid.Column="1" Content="Browse"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="BrowseDevRoot_Click" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- issues.md path -->
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="IssuesPathBox" Grid.Column="0"
                     materialDesign:HintAssist.Hint="Path to issues.md"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <Button Grid.Column="1" Content="Browse"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="BrowseIssues_Click" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- Theme -->
        <ComboBox x:Name="ThemeBox" Margin="0,0,0,16"
                  materialDesign:HintAssist.Hint="Theme"
                  materialDesign:HintAssist.IsFloating="True"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  DisplayMemberPath="Name"
                  SelectionChanged="ThemeBox_SelectionChanged"/>

        <!-- Project review frequency -->
        <ComboBox x:Name="ReviewFreqBox" Margin="0,0,0,16"
                  materialDesign:HintAssist.Hint="Shelved project review reminder"
                  materialDesign:HintAssist.IsFloating="True"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  DisplayMemberPath="Label"/>

        <!-- Global hotkey -->
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="HotkeyBox" Grid.Column="0" IsReadOnly="True"
                     materialDesign:HintAssist.Hint="Global hotkey (click to capture)"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Cursor="IBeam"
                     GotFocus="HotkeyBox_GotFocus"
                     LostFocus="HotkeyBox_LostFocus"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
            <Button Grid.Column="1" Content="Clear"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="ClearHotkey_Click" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- Archived projects -->
        <TextBlock Text="Archived projects"
                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                   Opacity="0.6" Margin="0,0,0,4"/>
        <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}"
                BorderThickness="1" CornerRadius="4" Opacity="0.9"
                Padding="0" MaxHeight="140" Margin="0,0,0,24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ArchivedPanel">
                    <TextBlock x:Name="EmptyArchivedText" Text="No archived projects"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.5" HorizontalAlignment="Center" Margin="0,16"/>
                    <ItemsControl x:Name="ArchivedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="12,4">
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Width="28" Height="28" Padding="4"
                                            ToolTip="Unarchive"
                                            Tag="{Binding}"
                                            Click="Unarchive_Click">
                                        <materialDesign:PackIcon Kind="ArchiveArrowUpOutline" Width="16" Height="16"/>
                                    </Button>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="CANCEL"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="SAVE"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
