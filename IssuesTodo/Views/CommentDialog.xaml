<Window x:Class="IssuesTodo.Views.CommentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Comment" Width="500" Height="340"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="CLEAR"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Clear_Click" Margin="0,0,8,0"/>
            <Button Content="CANCEL"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="SAVE"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="Save_Click"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Comment"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="TaskLabel"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Opacity="0.55" TextWrapping="Wrap"/>
        </StackPanel>

        <TextBox x:Name="CommentBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 materialDesign:HintAssist.Hint="Write a note for Claude or yourself..."
                 materialDesign:HintAssist.IsFloating="True"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 VerticalContentAlignment="Top"/>
    </DockPanel>
</Window>
