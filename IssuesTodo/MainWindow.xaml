<Window x:Class="IssuesTodo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:IssuesTodo.Views"
        xmlns:vm="clr-namespace:IssuesTodo.ViewModels"
        Title="Issues.TODO" Height="720" Width="1100" MinWidth="700" MinHeight="400"
        Icon="Assets/issues-todo.ico"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="160" MaxWidth="360"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <views:Sidebar Grid.Column="0"/>

        <!-- Divider line -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource MaterialDesign.Brush.Card.Background}"/>

        <!-- Main content -->
        <DockPanel Grid.Column="2">

            <!-- General todo — pinned above all project-based tasks -->
            <Border DockPanel.Dock="Top" Margin="20,16,20,0" Padding="20,14,20,12"
                    CornerRadius="8"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Todo"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,10"/>

                    <!-- Add input -->
                    <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding AddGeneralTodoCommand}"
                                ToolTip="Add todo" Margin="8,0,0,0">
                            <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"/>
                        </Button>
                        <ComboBox DockPanel.Dock="Right" Width="100"
                                  ItemsSource="{Binding PriorityOptions}"
                                  SelectedItem="{Binding NewGeneralTodoPriority}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="8,0,0,0"/>
                        <TextBox materialDesign:HintAssist.Hint="Add a general todo..."
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding NewGeneralTodoText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddGeneralTodoCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </DockPanel>

                    <!-- List -->
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GeneralTodos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                                    <Border x:Name="GeneralTodoRow" Padding="10,7" Margin="0,1"
                                            CornerRadius="6" Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#0DFFFFFF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <DockPanel>
                                            <Rectangle DockPanel.Dock="Left" Width="3" Margin="0,0,10,0"
                                                       RadiusX="1.5" RadiusY="1.5"
                                                       Fill="{Binding Model.Priority, Converter={StaticResource PriorityToBrush}}"/>
                                            <CheckBox DockPanel.Dock="Right"
                                                      IsChecked="{Binding IsDone}"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0,0,0"/>
                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding BeginEditCommand}"
                                                    ToolTip="Edit" Width="28" Height="28" Padding="5"
                                                    Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolToVis}}">
                                                <materialDesign:PackIcon Kind="PencilOutline" Width="14" Height="14"/>
                                            </Button>

                                            <Grid>
                                                <TextBlock Text="{Binding Model.Text}"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"
                                                           Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolToVis}}">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding BeginEditCommand}"/>
                                                    </TextBlock.InputBindings>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <DockPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                                        <ComboBox Width="90"
                                                                  ItemsSource="{Binding PriorityOptions}"
                                                                  SelectedItem="{Binding EditPriority}"
                                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                Command="{Binding CommitEditCommand}"
                                                                ToolTip="Save" Width="28" Height="28" Padding="5" Margin="4,0,0,0">
                                                            <materialDesign:PackIcon Kind="Check" Width="16" Height="16"/>
                                                        </Button>
                                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                Command="{Binding CancelEditCommand}"
                                                                ToolTip="Cancel" Width="28" Height="28" Padding="5">
                                                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                                        </Button>
                                                    </StackPanel>
                                                    <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                             VerticalAlignment="Center">
                                                        <TextBox.InputBindings>
                                                            <KeyBinding Key="Return" Command="{Binding CommitEditCommand}"/>
                                                            <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                                                        </TextBox.InputBindings>
                                                    </TextBox>
                                                </DockPanel>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Project area -->
            <Grid>
                <!-- Spinner while loading -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="48" Height="48"
                             VerticalAlignment="Center" HorizontalAlignment="Center"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                <!-- Project view when something is selected -->
                <ContentControl Content="{Binding SelectedProject}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:ProjectViewModel}">
                            <views:ProjectView/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Placeholder when nothing selected and not loading -->
                <TextBlock Text="Select a project"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasSelectedProject, Converter={StaticResource InvertBoolToVis}}"/>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
